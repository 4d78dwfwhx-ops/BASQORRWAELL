# تفعيل إعادة الكتابة
RewriteEngine On

# إعادة توجيه HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# الروابط النظيفة
RewriteRule ^product/([0-9]+)/?$ product.php?id=$1 [L,QSA]
RewriteRule ^category/([a-z0-9-]+)/?$ category.php?slug=$1 [L,QSA]
RewriteRule ^brand/([a-z0-9-]+)/?$ brand.php?slug=$1 [L,QSA]
RewriteRule ^search/?$ search.php [L,QSA]
RewriteRule ^cart/?$ cart.html [L]
RewriteRule ^checkout/?$ checkout.html [L]
RewriteRule ^login/?$ login.html [L]
RewriteRule ^register/?$ register.html [L]
RewriteRule ^track-order/?$ track-order.html [L]
RewriteRule ^admin/?$ admin/dashboard.php [L]

# منع الوصول للملفات الحساسة
<FilesMatch "\.(php|log|sql|json)$">
    Order allow,deny
    Allow from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# تحسين الأداء - ضغط Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# التخزين المؤقت للمتصفح
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
